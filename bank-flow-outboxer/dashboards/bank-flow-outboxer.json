{
  "uid": "bank-flow-outboxer",
  "title": "Bank Flow Outboxer",
  "tags": ["bank-flow", "outboxer"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Pending Events",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "outbox_pending_events or vector(0)", "legendFormat": "pending"}]
    },
    {
      "id": 2,
      "title": "Oldest Pending Event Age",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "outbox_oldest_pending_event_age_seconds or vector(0)", "legendFormat": "seconds"}]
    },
    {
      "id": 3,
      "title": "Publish Failures",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(outbox_publish_failures_total) or vector(0)", "legendFormat": "failures"}]
    },
    {
      "id": 4,
      "title": "Kafka Producer Send Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(rate(kafka_producer_topic_record_send_total{service=\"bank-flow-outboxer\"}[$__rate_interval])) or vector(0)", "legendFormat": "records/sec"}]
    },
    {
      "id": 5,
      "title": "Publish Failures By Producer",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum by (producer_service, topic, event_type) (rate(outbox_publish_failures_total[$__rate_interval]))", "legendFormat": "{{producer_service}} {{topic}} {{event_type}}"}]
    },
    {
      "id": 6,
      "title": "Kafka Producer Records By Topic",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "sum by (topic) (rate(kafka_producer_topic_record_send_total{service=\"bank-flow-outboxer\"}[$__rate_interval]))", "legendFormat": "{{topic}}"}]
    },
    {
      "id": 7,
      "title": "Kafka Consumer Lag By Group",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [{"expr": "sum by (consumergroup, topic) (kafka_consumergroup_lag{consumergroup=~\"bank-flow-.*\"})", "legendFormat": "{{consumergroup}} {{topic}}"}]
    }
  ]
}
