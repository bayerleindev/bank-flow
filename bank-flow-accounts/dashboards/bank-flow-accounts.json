{
  "uid": "bank-flow-accounts",
  "title": "Bank Flow Accounts",
  "tags": ["bank-flow", "accounts"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Accounts Created",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(accounts_created_total) or vector(0)", "legendFormat": "created"}]
    },
    {
      "id": 2,
      "title": "Pending Outbox Events",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "outbox_pending_events{service=\"bank-flow-accounts\"} or vector(0)", "legendFormat": "pending"}]
    },
    {
      "id": 3,
      "title": "Oldest Pending Outbox Age",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "outbox_oldest_pending_event_age_seconds{service=\"bank-flow-accounts\"} or vector(0)", "legendFormat": "seconds"}]
    },
    {
      "id": 4,
      "title": "Outbox Publish Failures",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(outbox_publish_failures_total{service=\"bank-flow-accounts\"}) or vector(0)", "legendFormat": "failures"}]
    },
    {
      "id": 5,
      "title": "Accounts By Status",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum by (status) (accounts_in_status)", "legendFormat": "{{status}}"}]
    },
    {
      "id": 6,
      "title": "Oldest Account Age By Status",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "max by (status) (account_oldest_in_status_age_seconds)", "legendFormat": "{{status}}"}]
    },
    {
      "id": 7,
      "title": "Account Creation Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "sum(rate(accounts_created_total[$__rate_interval])) or vector(0)", "legendFormat": "accounts/sec"}]
    },
    {
      "id": 8,
      "title": "Outbox Publish Failure Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{"expr": "sum by (topic, event_type) (rate(outbox_publish_failures_total{service=\"bank-flow-accounts\"}[$__rate_interval]))", "legendFormat": "{{topic}} {{event_type}}"}]
    }
  ]
}
