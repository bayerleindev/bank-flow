{
  "uid": "bank-flow-yield",
  "title": "Bank Flow Yield",
  "tags": ["bank-flow", "yield"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Accruals Pending Posting",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "sum(yield_accruals_in_status{status=\"PENDING\"}) or vector(0)", "legendFormat": "pending"}]
    },
    {
      "id": 2,
      "title": "Accruals Posting Requested",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "sum(yield_accruals_in_status{status=\"POSTING_REQUESTED\"}) or vector(0)", "legendFormat": "requested"}]
    },
    {
      "id": 3,
      "title": "Accruals Posted",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(yield_accruals_in_status{status=\"POSTED\"}) or vector(0)", "legendFormat": "posted"}]
    },
    {
      "id": 4,
      "title": "CDI Rates Stored",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "yield_cdi_rates_total or vector(0)", "legendFormat": "rates"}]
    },
    {
      "id": 5,
      "title": "Accruals By Status",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum by (status) (yield_accruals_in_status)", "legendFormat": "{{status}}"}]
    },
    {
      "id": 6,
      "title": "Oldest Accrual Age By Status",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "max by (status) (yield_oldest_accrual_in_status_age_seconds)", "legendFormat": "{{status}}"}]
    },
    {
      "id": 7,
      "title": "Request Rate By Endpoint",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{service=\"bank-flow-yield\", uri!~\"/actuator.*\"}[$__rate_interval]))", "legendFormat": "{{method}} {{uri}} {{status}}"}]
    },
    {
      "id": 8,
      "title": "Request Latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum(rate(http_server_requests_seconds_sum{service=\"bank-flow-yield\", uri!~\"/actuator.*\"}[$__rate_interval])) / sum(rate(http_server_requests_seconds_count{service=\"bank-flow-yield\", uri!~\"/actuator.*\"}[$__rate_interval]))", "legendFormat": "avg"},
        {"expr": "max(http_server_requests_seconds_max{service=\"bank-flow-yield\", uri!~\"/actuator.*\"})", "legendFormat": "max"}
      ]
    }
  ]
}
