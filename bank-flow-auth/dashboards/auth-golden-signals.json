{
  "uid": "auth-golden-signals",
  "title": "Bank Flow Auth - Golden Signals",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["auth", "golden-signals"],
  "time": {"from": "now-30m", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "application",
        "label": "Application",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values({application=~\"bank-flow-auth.*\"}, application)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {"selected": true, "text": ["All"], "value": ["$__all"]}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Traffic - HTTP Requests",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (application, method, uri) (rate(http_server_requests_seconds_count{application=~\"$application\"}[5m]))", "legendFormat": "{{application}} {{method}} {{uri}}"}
      ]
    },
    {
      "id": 2,
      "title": "Errors - HTTP 5xx",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (application, status, uri) (rate(http_server_requests_seconds_count{application=~\"$application\", status=~\"5..\"}[5m]))", "legendFormat": "{{application}} {{status}} {{uri}}"}
      ]
    },
    {
      "id": 3,
      "title": "Duration - HTTP p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le, application, method, uri) (rate(http_server_requests_seconds_bucket{application=~\"$application\"}[5m])))", "legendFormat": "{{application}} {{method}} {{uri}}"}
      ]
    },
    {
      "id": 4,
      "title": "Saturation - JVM Memory",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "100 * sum by (application, area) (jvm_memory_used_bytes{application=~\"$application\"}) / sum by (application, area) (jvm_memory_max_bytes{application=~\"$application\"} > 0)", "legendFormat": "{{application}} {{area}}"}
      ]
    },
    {
      "id": 5,
      "title": "Saturation - CPU",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "100 * avg by (application) (process_cpu_usage{application=~\"$application\"})", "legendFormat": "{{application}}"}
      ]
    },
    {
      "id": 6,
      "title": "Kafka Traffic",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (service, messaging_destination_name, messaging_source_name, messaging_operation) (rate(traces_spanmetrics_calls_total{service=~\"$application\", messaging_system=\"kafka\"}[5m]))", "legendFormat": "{{service}} {{messaging_operation}} {{messaging_destination_name}}{{messaging_source_name}}"}
      ]
    },
    {
      "id": 7,
      "title": "Errors - Traces",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (service, span_name) (rate(traces_spanmetrics_calls_total{service=~\"$application\", status_code=\"ERROR\"}[5m]))", "legendFormat": "{{service}} {{span_name}}"}
      ]
    },
    {
      "id": 8,
      "title": "Trace Duration p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le, service, span_name) (rate(traces_spanmetrics_latency_bucket{service=~\"$application\"}[5m])))", "legendFormat": "{{service}} {{span_name}}"}
      ]
    },
    {
      "id": 9,
      "title": "Resilience4j Calls",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (application, name, kind) (rate(resilience4j_circuitbreaker_calls_seconds_count{application=~\"$application\"}[5m]))", "legendFormat": "{{application}} {{name}} {{kind}}"}
      ]
    }
  ]
}
