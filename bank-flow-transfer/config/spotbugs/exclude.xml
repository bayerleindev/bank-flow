<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">
    <!-- False positives for Spring-injected mutable beans -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2" />
        <Or>
            <Class name="br.com.bankflow.transfer.observability.TransferTracing" />
            <Class name="br.com.bankflow.transfer.observability.TransferBusinessMetrics" />
            <Class name="br.com.bankflow.transfer.services.TransferOrchestrationService" />
            <Class name="br.com.bankflow.transfer.repositories.JdbcTransferRepository" />
            <Class name="br.com.bankflow.transfer.repositories.JdbcOutboxEventRepository" />
            <Class name="br.com.bankflow.transfer.consumers.LedgerPostingCreatedConsumer" />
        </Or>
    </Match>
</FindBugsFilter>
