        },
        {
          "expr": "(sum(transfer_psp_confirmed_total) or vector(0)) / clamp_min((sum(balance_holds_created_total) or sum(balance_holds_total) or vector(0)), 1)",
          "legendFormat": "hold_to_psp"
        },
        {
          "expr": "(sum(ledger_posting_created_total) or sum(ledger_posting_total) or vector(0)) / clamp_min((sum(transfer_psp_confirmed_total) or vector(0)), 1)",
          "legendFormat": "psp_to_ledger"
        },
        {
          "expr": "(sum(balance_holds_captured_total) or vector(0)) / clamp_min((sum(ledger_posting_created_total) or sum(ledger_posting_total) or vector(0)), 1)",
          "legendFormat": "ledger_to_capture"
        },
        {
          "expr": "(sum(transfers_completed_total) or vector(0)) / clamp_min((sum(transfers_created_total) or sum(transfers_total) or vector(0)), 1)",
          "legendFormat": "created_to_completed"
        },
        {
          "expr": "(sum(transfers_failed_total) or vector(0)) / clamp_min((sum(transfers_created_total) or sum(transfers_total) or vector(0)), 1)",
          "legendFormat": "created_to_failed"
